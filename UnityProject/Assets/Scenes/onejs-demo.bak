import { render, View, Label, Button, Slider } from "onejs-react"
import { useState } from "react"

function Demo() {
    const [count, setCount] = useState(0)
    const [hue, setHue] = useState(180)

    const onClick = () => {
        setCount(c => c + 1)
        CS.UnityEngine.Debug.Log(`Clicked at t=${CS.UnityEngine.Time.time.toFixed(2)}`)
    }

    return (
        <View style={{ padding: 20, backgroundColor: `hsl(${hue}, 60%, 25%)` }}>
            <Label text={`Count: ${count}`} style={{ color: "white", fontSize: 24 }} />
            <Button text="Click me" onClick={onClick} style={{ marginTop: 8 }} />
            <Label text={`Hue: ${hue}`} style={{ color: "white", marginTop: 16 }} />
            <Slider
                value={hue}
                lowValue={0}
                highValue={360}
                onChange={(e) => setHue(e.value)}
                style={{ width: 240 }}
            />
        </View>
    )
}

render(<Demo />, __root)
